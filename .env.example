# Variables de entorno - Shanklish Caracas ERP
# Copiar este archivo a .env.local y configurar los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/shanklish_erp?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu-secret-aqui-generar-con-openssl-rand-base64-32"

# Configuración del sistema
NEXT_PUBLIC_APP_NAME="Shanklish Caracas ERP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Moneda por defecto
NEXT_PUBLIC_DEFAULT_CURRENCY="USD"
