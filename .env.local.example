# =============================================================================
# SHANKLISH CARACAS ERP - Configuración de Entorno
# =============================================================================
# Copia este archivo a .env.local y modifica los valores según tu entorno
# NUNCA subas .env.local a Git (ya está en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS POSTGRESQL (Supabase)
# -----------------------------------------------------------------------------
# 
# Para DESARROLLO LOCAL con PostgreSQL local:
# DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/shanklish_erp?schema=public"
# DIRECT_URL="postgresql://postgres:tu_password@localhost:5432/shanklish_erp?schema=public"
#
# Para PRODUCCIÓN con Supabase:
# DATABASE_URL = URL con pooling (puerto 6543)
# DIRECT_URL = URL directa (puerto 5432) - Solo para migraciones
#

# URL con Connection Pooling (para la aplicación)
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL Directa (para migraciones de Prisma)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NEXTAUTH (Autenticación)
# -----------------------------------------------------------------------------
# URL de tu aplicación
# Desarrollo: http://localhost:3000
# Producción: https://tu-proyecto.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Secret para encriptar sesiones
# Generar con: openssl rand -base64 32
# O usar: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="genera-un-secret-seguro-aqui-con-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# SUPABASE (Storage para imágenes)
# -----------------------------------------------------------------------------
# Obtener de: Supabase Dashboard → Project Settings → API

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Clave pública (anon key) - Segura para el frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Clave privada (service role) - SOLO para backend, NUNCA exponer al frontend
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE APLICACIÓN
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Shanklish Caracas ERP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Moneda por defecto para costos
NEXT_PUBLIC_DEFAULT_CURRENCY="USD"

# -----------------------------------------------------------------------------
# SOLO DESARROLLO LOCAL
# -----------------------------------------------------------------------------
# Carpeta para guardar archivos subidos (solo desarrollo)
# En producción, los archivos van a Supabase Storage
UPLOAD_DIR="./public/uploads"

# Descomenta para ver logs de Prisma
# DEBUG="prisma:*"
