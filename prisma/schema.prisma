// ============================================================================
// SHANKLISH CARACAS ERP - PRISMA SCHEMA
// ============================================================================
// Base de Datos: Google Cloud SQL (PostgreSQL)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USUARIOS Y AUTENTICACIÃ“N
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  firstName     String
  lastName      String
  role          String    @default("CHEF") // OWNER, AUDITOR, ADMIN_MANAGER, OPS_MANAGER, CHEF, AREA_LEAD
  pin           String?   // CÃ³digo de 4-6 dÃ­gitos para autorizaciÃ³n rÃ¡pida
  allowedModules String?  // JSON array de módulos permitidos (null = acceso por rol)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Soft Delete
  deletedAt     DateTime?
  deletedById   String?

  // Relaciones
  inventoryMovements InventoryMovement[]
  costHistories      CostHistory[]
  productionOrders   ProductionOrder[]

  // Requisiciones
  requisitionsRequested Requisition[] @relation("RequisitionRequester")
  requisitionsProcessed Requisition[] @relation("RequisitionProcessor")
  requisitionsDispatched Requisition[] @relation("RequisitionDispatcher")
  requisitionsReceived  Requisition[] @relation("RequisitionReceiver")

  // POS - Ventas
  salesOrders    SalesOrder[] @relation("SalesOrderCreator")
  authorizedOrders SalesOrder[] @relation("SalesOrderAuthorizer")
  voidedOrders   SalesOrder[] @relation("SalesOrderVoider")
  openedTabs       OpenTab[]    @relation("OpenTabOpener")
  assignedTabs     OpenTab[]    @relation("OpenTabAssignee")
  closedTabs       OpenTab[]    @relation("OpenTabCloser")
  
  // Cierres de Inventario
  closedDailyInventories DailyInventory[]

  // Recetas creadas
  createdRecipes Recipe[]
  
  // PrÃ©stamos creados
  createdLoans InventoryLoan[] @relation("LoanCreator")

  // Auditorías
  createdAudits   InventoryAudit[] @relation("AuditCreator")
  resolvedAudits  InventoryAudit[] @relation("AuditResolver")

  // Órdenes de Compra
  createdPurchaseOrders  PurchaseOrder[] @relation("PurchaseOrderCreator")
  receivedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderReceiver")

  // Procesamiento de Proteínas
  createdProteinProcessings   ProteinProcessing[] @relation("ProteinProcessingCreator")
  completedProteinProcessings ProteinProcessing[] @relation("ProteinProcessingCompleter")

  // Módulo Juegos
  reservationsCreated GameSession[]    @relation("GameSessionStarter")
  gameSessionsEnded   GameSession[]    @relation("GameSessionEnder")
  createdReservations Reservation[]    @relation("ReservationCreator")

  // Módulo Financiero
  createdExpenses         Expense[]         @relation("ExpenseCreator")
  openedCashRegisters     CashRegister[]    @relation("CashRegisterOpener")
  closedCashRegisters     CashRegister[]    @relation("CashRegisterCloser")
  createdAccountsPayable  AccountPayable[]  @relation("AccountPayableCreator")
  createdAccountPayments  AccountPayment[]  @relation("AccountPaymentCreator")

  @@index([email])
  @@index([role])
}

// ============================================================================
// Ã�REAS DE TRABAJO
// ============================================================================

model Area {
  id          String   @id @default(cuid())
  name        String
  description String?
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Relaciones
  inventoryLocations InventoryLocation[]
  inventoryMovements InventoryMovement[]

  // Requisiciones
  requisitionsTarget Requisition[] @relation("RequisitionTarget")
  requisitionsSource Requisition[] @relation("RequisitionSource")

  // POS - Ventas
  salesOrders    SalesOrder[]
  
  // Inventarios Diarios
  dailyInventories DailyInventory[]

  // Auditorías
  audits         InventoryAudit[]

  // Procesamiento de Proteínas
  proteinProcessings ProteinProcessing[]

  // Items críticos por área
  criticalItems    AreaCriticalItem[]

  @@index([branchId])
}

// ============================================================================
// INVENTARIO
// ============================================================================

model InventoryItem {
  id              String   @id @default(cuid())
  sku             String   @unique
  name            String
  description     String?
  type            String   // RAW_MATERIAL, SUB_RECIPE, FINISHED_GOOD
  category        String?
  baseUnit        String   // KG, L, UNIT, G, ML, PORTION
  purchaseUnit    String?
  conversionRate  Float?
  minimumStock    Float    @default(0)
  reorderPoint    Float    @default(0)
  isActive        Boolean  @default(true)
  isCritical      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  // Relaciones
  stockLevels     InventoryLocation[]
  movements       InventoryMovement[]
  costHistory     CostHistory[]
  recipeIngredients RecipeIngredient[]
  outputRecipes   Recipe[]            @relation("RecipeOutput")

  requisitionItems RequisitionItem[]
  
  // Préstamos
  loans            InventoryLoan[]
  
  // Inventario Diario
  dailyCounts      DailyInventoryItem[]

  // Auditorías
  auditItems     InventoryAuditItem[]

  // Órdenes de Compra
  supplierItems      SupplierItem[]
  purchaseOrderItems PurchaseOrderItem[]

  // Procesamiento de Proteínas
  proteinSources     ProteinProcessing[] @relation("ProteinSource")
  proteinOutputs     ProteinSubProduct[] @relation("ProteinOutput")

  // Plantillas de Procesamiento
  templateSources    ProcessingTemplate[]       @relation("TemplateSource")
  templateOutputs    ProcessingTemplateOutput[] @relation("TemplateOutput")

  // Items críticos por área
  areaCriticalItems  AreaCriticalItem[]

  // ── Beverage fields (Table-Pong / bar) ──────────────────────────────────
  isBeverage         Boolean  @default(false)
  beverageCategory   String?  // BEER, WINE, SPIRIT, COCKTAIL, SOFT_DRINK, WATER, JUICE, HOT
  beverageSubCategory String? // IPA, LAGER, ROSÉ, etc.
  isAlcoholic        Boolean  @default(false)
  servingSize        Float?   // Standard serving in baseUnit
  servingSizeUnit    String?  // CL, ML, OZ

  // Familia de producto (SKU Studio)
  productFamilyId    String?
  productFamily      ProductFamily? @relation(fields: [productFamilyId], references: [id])

  // Conteos Físicos (InventoryCycle)
  cycleSnapshots     InventoryCycleSnapshot[]

  @@index([sku])
  @@index([type])
  @@index([category])
  @@index([name])
  @@index([isBeverage])
  @@index([productFamilyId])
}

// ============================================================================
// ITEMS CRÍTICOS POR ÁREA (Lista independiente por ubicación)
// ============================================================================

model AreaCriticalItem {
  id              String        @id @default(cuid())
  areaId          String
  area            Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([areaId, inventoryItemId])
  @@index([areaId])
}

model InventoryLocation {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  areaId          String
  area            Area          @relation(fields: [areaId], references: [id])
  currentStock    Float         @default(0)
  lastCountDate   DateTime?
  
  @@unique([inventoryItemId, areaId])
  @@index([inventoryItemId])
  @@index([areaId])
}

// ============================================================================
// MOVIMIENTOS DE INVENTARIO
// ============================================================================

model InventoryMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  movementType    String   // PURCHASE, SALE, PRODUCTION_IN, PRODUCTION_OUT, ADJUSTMENT_IN, ADJUSTMENT_OUT, TRANSFER, WASTE
  quantity        Float
  unit            String
  
  // Costo
  unitCost        Float?
  totalCost       Float?
  
  // Documento de soporte
  referenceNumber String?
  documentUrl     String?
  documentType    String?
  
  // Notas
  reason          String?
  notes           String?
  
  // AuditorÃ­a
  createdAt       DateTime @default(now())
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])

  // VinculaciÃ³n con venta (si aplica)
  salesOrderId    String?
  salesOrder      SalesOrder? @relation("SaleMovements", fields: [salesOrderId], references: [id])

  // VinculaciÃ³n con prÃ©stamo
  loanId          String?
  loan            InventoryLoan? @relation(fields: [loanId], references: [id])

  // Ubicación del movimiento
  areaId          String?
  area            Area?    @relation(fields: [areaId], references: [id])

  // Vinculaciones cruzadas (trazabilidad completa)
  productionOrderId  String?
  requisitionId      String?
  purchaseOrderId    String?
  auditId            String?
  proteinProcessingId String?

  @@index([inventoryItemId])
  @@index([movementType])
  @@index([createdAt])
  @@index([salesOrderId])
  @@index([loanId])
  @@index([createdById])
  @@index([areaId])
  @@index([productionOrderId])
  @@index([requisitionId])
  @@index([purchaseOrderId])
}

// ============================================================================
// HISTORIAL DE COSTOS
// ============================================================================

model CostHistory {
  id              String   @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  costPerUnit     Float
  currency        String   @default("USD")
  isCalculated    Boolean  @default(false)
  costBreakdown   String?  // JSON string
  
  effectiveFrom   DateTime @default(now())
  effectiveTo     DateTime?
  
  reason          String?
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])

  @@index([inventoryItemId])
  @@index([effectiveFrom])
}

// ============================================================================
// RECETAS
// ============================================================================

model Recipe {
  id              String   @id @default(cuid())
  name            String
  description     String?
  
  outputItemId    String
  outputItem      InventoryItem @relation("RecipeOutput", fields: [outputItemId], references: [id])
  outputQuantity  Float    @default(1)
  outputUnit      String
  
  yieldPercentage Float    @default(100)
  prepTime        Int?
  cookTime        Int?
  
  isApproved      Boolean  @default(false)
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id])

  // Relaciones
  ingredients     RecipeIngredient[]
  productionOrders ProductionOrder[]

  @@index([outputItemId])
}

model RecipeIngredient {
  id              String   @id @default(cuid())
  recipeId        String
  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  ingredientItemId String
  ingredientItem   InventoryItem @relation(fields: [ingredientItemId], references: [id])
  
  quantity        Float
  unit            String
  wastePercentage Float    @default(0)
  notes           String?
  sortOrder       Int      @default(0)

  @@unique([recipeId, ingredientItemId])
  @@index([recipeId])
}

// ============================================================================
// Ã“RDENES DE PRODUCCIÃ“N
// ============================================================================

model ProductionOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  
  recipeId        String
  recipe          Recipe   @relation(fields: [recipeId], references: [id])
  
  outputItemId    String
  plannedQuantity Float
  actualQuantity  Float?
  unit            String
  
  status          String   @default("DRAFT") // DRAFT, APPROVED, IN_PROGRESS, COMPLETED, CANCELLED
  priority        Int      @default(0)
  
  scheduledDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  actualYieldPercentage Float?
  actualCost      Float?
  
  notes           String?
  
  createdAt       DateTime @default(now())
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([status])
  @@index([scheduledDate])
}

// ============================================================================
// PROCESAMIENTO Y DESPOSTE DE PROTEÍNAS
// ============================================================================

model ProteinProcessing {
  id              String   @id @default(cuid())
  code            String   @unique // Ej: PROT-2026-001
  
  // Fecha del procesamiento
  processDate     DateTime @default(now())
  
  // Producto a procesar (item del inventario - ej: Res entera, Pollo entero)
  sourceItemId    String
  sourceItem      InventoryItem @relation("ProteinSource", fields: [sourceItemId], references: [id])
  
  // Proveedor (opcional)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  supplierName    String?   // Por si no está en el sistema
  
  // Pesos
  frozenWeight    Float     // Peso congelado inicial (kg)
  drainedWeight   Float     // Peso escurrido/descongelado (kg)
  
  // Totales calculados
  totalSubProducts Float    @default(0) // Suma de pesos de subproductos
  wasteWeight     Float     @default(0) // Desperdicio (kg) calculado (Drained - SubProducts)
  reportedWaste   Float?                // Desperdicio reportado manualmente (kg)
  wastePercentage Float     @default(0) // % de desperdicio
  yieldPercentage Float     @default(0) // % de rendimiento
  
  // Estado
  status          String    @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED
  
  // Paso del procesamiento en cadena
  processingStep  String    @default("LIMPIEZA") // LIMPIEZA, MASERADO, DISTRIBUCION, CUSTOM
  
  // Encadenamiento: referencia al procesamiento padre (si es un paso posterior)
  parentProcessingId String?
  parentProcessing   ProteinProcessing?  @relation("ProcessingChain", fields: [parentProcessingId], references: [id])
  childProcessings   ProteinProcessing[] @relation("ProcessingChain")
  
  // Área donde se realiza el procesamiento
  areaId          String
  area            Area      @relation(fields: [areaId], references: [id])
  
  notes           String?
  
  // Auditoría
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String
  createdBy       User      @relation("ProteinProcessingCreator", fields: [createdById], references: [id])
  completedAt     DateTime?
  completedById   String?
  completedBy     User?     @relation("ProteinProcessingCompleter", fields: [completedById], references: [id])
  
  // Subproductos resultantes
  subProducts     ProteinSubProduct[]

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?
  
  @@index([processDate])
  @@index([status])
  @@index([sourceItemId])
  @@index([parentProcessingId])
}

model ProteinSubProduct {
  id              String   @id @default(cuid())
  
  processingId    String
  processing      ProteinProcessing @relation(fields: [processingId], references: [id], onDelete: Cascade)
  
  // Item de inventario resultante (ej: Lomo, Costilla, Pechuga)
  outputItemId    String?
  outputItem      InventoryItem? @relation("ProteinOutput", fields: [outputItemId], references: [id])
  
  // Nombre del subproducto (por si no está en inventario)
  name            String
  
  // Peso y unidades obtenidas
  weight          Float     // Peso en kg
  units           Int       @default(1) // Cantidad de piezas
  unitType        String    @default("KG") // KG, UNIDAD, PIEZA
  
  // Costo calculado (proporcional al peso)  
  estimatedCost   Float     @default(0)
  
  notes           String?
  sortOrder       Int       @default(0)
  
  @@index([processingId])
  @@index([outputItemId])
}

// ============================================================================
// PLANTILLAS DE PROCESAMIENTO DE PROTEÍNAS
// ============================================================================

model ProcessingTemplate {
  id              String   @id @default(cuid())
  name            String   // Ej: "Procesamiento de Lomito", "Procesamiento de Pollo"
  description     String?
  
  // Item fuente (materia prima)
  sourceItemId    String
  sourceItem      InventoryItem @relation("TemplateSource", fields: [sourceItemId], references: [id])
  
  // Paso de procesamiento que esta plantilla cubre (puede haber varias plantillas por item fuente, una por paso)
  processingStep  String   @default("LIMPIEZA") // LIMPIEZA, MASERADO, DISTRIBUCION, CUSTOM
  
  // Si el peso de salida puede ser mayor al de entrada (ej: maserado agrega condimentos)
  canGainWeight   Boolean  @default(false)
  
  // Orden en la cadena de pasos para este item fuente
  chainOrder      Int      @default(0) // 0=primer paso, 1=segundo, etc.
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Sub-productos permitidos en este paso
  allowedOutputs  ProcessingTemplateOutput[]
  
  @@index([sourceItemId])
  @@index([processingStep])
}

model ProcessingTemplateOutput {
  id              String   @id @default(cuid())
  templateId      String  
  template        ProcessingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  // Item de salida permitido
  outputItemId    String
  outputItem      InventoryItem @relation("TemplateOutput", fields: [outputItemId], references: [id])
  
  // Peso esperado (referencia para el usuario)
  expectedWeight  Float?     // Peso promedio esperado en KG
  expectedUnits   Int?       // Unidades esperadas
  sortOrder       Int        @default(0)
  
  // Indica si este output es un producto intermedio (input del siguiente paso) o un producto final
  isIntermediate  Boolean    @default(false) // true = se usa como input del siguiente paso
  
  @@unique([templateId, outputItemId])
  @@index([templateId])
}

// ============================================================================
// REQUISICIONES (TRANSFERENCIAS ENTRE ALMACENES)
// ============================================================================

model Requisition {
  id          String   @id @default(cuid())
  code        String   @unique // Ej: REQ-1001
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  
  // QuiÃ©n pide (Solicitante)
  requestedById String
  requestedBy   User     @relation("RequisitionRequester", fields: [requestedById], references: [id])
  
  // Para quÃ© Ã¡rea pide (Destino)
  targetAreaId  String
  targetArea    Area     @relation("RequisitionTarget", fields: [targetAreaId], references: [id])
  
  // De dÃ³nde se saca (Origen - Generalmente AlmacÃ©n Principal, pero puede variar)
  sourceAreaId  String?
  sourceArea    Area?    @relation("RequisitionSource", fields: [sourceAreaId], references: [id])

  // Quién aprueba/recepciona (Gerente Operativo)
  processedById String?
  processedBy   User?    @relation("RequisitionProcessor", fields: [processedById], references: [id])
  processedAt   DateTime?

  // Quién despacha (Jefe de Producción) - para flujo escalonado
  dispatchedById String?
  dispatchedBy   User?    @relation("RequisitionDispatcher", fields: [dispatchedById], references: [id])
  dispatchedAt   DateTime?

  // Quién recibe (Jefe de Cocina / Receptor) - verificación de recepción
  receivedById   String?
  receivedBy     User?    @relation("RequisitionReceiver", fields: [receivedById], references: [id])
  receivedAt     DateTime?
  
  notes       String?

  items       RequisitionItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([status])
  @@index([requestedById])
  @@index([targetAreaId])
}

model RequisitionItem {
  id            String      @id @default(cuid())
  requisitionId String
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  quantity      Float       // Cantidad solicitada por el Chef
  unit          String
  
  // Cantidades por etapa del flujo escalonado
  sentQuantity       Float?   // Lo que realmente envió el Jefe de Producción
  receivedQuantity   Float?   // Lo que confirmó el Gerente que llegó
  dispatchedQuantity Float?   // Retrocompat: alias de sentQuantity
  
  @@index([requisitionId])
}

// ============================================================================
// SISTEMA POS - MENÃš
// ============================================================================

model MenuCategory {
  id          String   @id @default(cuid())
  name        String   // Ej: "Shawarmas", "Bebidas", "Postres"
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?
  
  // Relaciones
  items       MenuItem[]
  
  @@index([sortOrder])
}

model MenuItem {
  id              String   @id @default(cuid())
  sku             String   @unique // Ej: "SHWRM-MIX", "BEB-PEPSI"
  name            String   // Ej: "Shawarma Mixto"
  description     String?
  
  categoryId      String
  category        MenuCategory @relation(fields: [categoryId], references: [id])
  
  // Precios
  price           Float    // Precio de venta en USD
  cost            Float?   // Costo calculado (si tiene receta)
  
  // VinculaciÃ³n con inventario/receta (opcional)
  recipeId        String?  // Si el producto tiene receta para descontar insumos
  
  // ConfiguraciÃ³n
  isAvailable     Boolean  @default(true)
  isActive        Boolean  @default(true)

  // POS Navigation
  posGroup        String?  // Agrupa variantes de tamaño (ej: "Shawarma Carne" para 250gr/350gr/500gr)
  posSubcategory  String?  // Subcategoría visual en POS (ej: "Jugos", "Cafés")
  
  // Modificadores permitidos
  modifierGroups  MenuItemModifierGroup[]

  // Modificadores vinculados (para descargo de inventario por componente elegido)
  linkedModifiers MenuModifier[] @relation("ModifierLinkedItem")

  // Relaciones
  orderItems      SalesOrderItem[]

  // ── Service routing ─────────────────────────────────────────────────────
  serviceCategory  String?  // FOOD, BEVERAGE, GAME_TIME, MERCHANDISE
  kitchenRouting   String?  // BAR, KITCHEN, GRILL, COLD_STATION — destino de comanda

  // ── Intercompany ─────────────────────────────────────────────────────────
  isIntercompanyItem    Boolean @default(false)  // Viene de otro negocio
  externalSku           String? // SKU en el sistema origen
  sourceBranchId        String? // Branch que lo origina
  intercompanyMappings  IntercompanyItemMapping[] @relation("IntercompanyMenuItem")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([categoryId])
  @@index([sku])
  @@index([serviceCategory])
  @@index([isIntercompanyItem])
}

model MenuModifierGroup {
  id              String   @id @default(cuid())
  name            String   // Ej: "AcompaÃ±antes", "TamaÃ±o", "Extras"
  description     String?
  
  // Reglas de selecciÃ³n
  isRequired      Boolean  @default(false) // Debe seleccionar al menos uno
  minSelections   Int      @default(0)
  maxSelections   Int      @default(99)    // 99 = sin lÃ­mite
  
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  // Relaciones
  modifiers       MenuModifier[]
  menuItems       MenuItemModifierGroup[]
  
  createdAt       DateTime @default(now())
}

model MenuModifier {
  id              String   @id @default(cuid())
  groupId         String
  group           MenuModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  name            String   // Ej: "TabulÃ©", "Vegetales Salteados"
  priceAdjustment Float    @default(0) // +$0.50, -$1.00, etc.

  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)

  // Vínculo a MenuItem para descargo de inventario por modificador
  // Cuando el cliente elige este modificador, se descarga la receta del plato vinculado
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation("ModifierLinkedItem", fields: [linkedMenuItemId], references: [id])

  // Relaciones
  orderItemModifiers SalesOrderItemModifier[]

  @@index([groupId])
  @@index([linkedMenuItemId])
}

// Tabla pivote: QuÃ© grupos de modificadores aplican a quÃ© productos
model MenuItemModifierGroup {
  id              String   @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  modifierGroupId String
  modifierGroup   MenuModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  
  @@unique([menuItemId, modifierGroupId])
}

// ============================================================================
// SISTEMA POS - VENTAS
// ============================================================================

model SalesOrder {
  id              String   @id @default(cuid())
  
  // Correlativo Ãºnico por dÃ­a (Ej: "REST-2026-01-27-001")
  orderNumber     String   @unique
  
  // Tipo de venta
  orderType       String   @default("RESTAURANT") // RESTAURANT, DELIVERY
  serviceFlow     String   @default("DIRECT_SALE") // DIRECT_SALE, OPEN_TAB, TAB_CLOSING
  sourceChannel   String   @default("POS_RESTAURANT")
  
  // Cliente (opcional)
  customerName    String?
  customerPhone   String?
  customerAddress String?  // Para delivery
  
  // Estado
  status          String   @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, DELIVERED, CANCELLED
  kitchenStatus   String   @default("NOT_SENT") // NOT_SENT, SENT, IN_PROGRESS, READY, NOT_REQUIRED
  
  // Totales
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  tax             Float    @default(0)
  total           Float    @default(0)

  // Detalles de Descuento
  discountType    String?  // DIVISAS_33, CORTESIA_100, etc.
  discountReason  String?
  authorizedById  String?
  authorizedBy    User?    @relation("SalesOrderAuthorizer", fields: [authorizedById], references: [id])

  // Anulación
  voidedAt        DateTime?
  voidedById      String?
  voidedBy        User?    @relation("SalesOrderVoider", fields: [voidedById], references: [id])
  voidReason      String?

  // MÃ©todo de pago
  
  // MÃ©todo de pago
  paymentMethod   String?  // CASH, CARD, TRANSFER, MULTIPLE
  paymentStatus   String   @default("PENDING") // PENDING, PAID, PARTIAL, REFUNDED
  amountPaid      Float    @default(0)
  change          Float    @default(0) // Vuelto
  
  // AuditorÃ­a
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sentToKitchenAt DateTime?
  closedAt        DateTime?
  
  // Cajera que creÃ³ la orden
  createdById     String
  createdBy       User     @relation("SalesOrderCreator", fields: [createdById], references: [id])
  
  // Ã�rea de la que se descuenta inventario
  areaId          String
  area            Area     @relation(fields: [areaId], references: [id])
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  serviceZoneId   String?
  serviceZone     ServiceZone? @relation(fields: [serviceZoneId], references: [id])
  tableOrStationId String?
  tableOrStation  TableOrStation? @relation(fields: [tableOrStationId], references: [id])
  openTabId       String?
  openTab         OpenTab? @relation(fields: [openTabId], references: [id])

  // Snapshot financiero
  exchangeRateId    String?
  exchangeRate      ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  exchangeRateValue Float?
  totalBs           Float?
  
  // Notas
  notes           String?
  
  // LÃ­neas de la orden
  items           SalesOrderItem[]
  
  // Movimientos de inventario generados
  inventoryMovements InventoryMovement[] @relation("SaleMovements")
  openTabLinks       OpenTabOrder[]
  paymentSplits      PaymentSplit[]
  gameSessions       GameSession[]       @relation("GameSessions")

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?
  
  @@index([orderNumber])
  @@index([orderType])
  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([serviceFlow])
  @@index([kitchenStatus])
  @@index([branchId])
  @@index([serviceZoneId])
  @@index([tableOrStationId])
  @@index([openTabId])
}

model SalesOrderItem {
  id              String   @id @default(cuid())
  
  orderId         String
  order           SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  
  // Snapshot del nombre y precio al momento de la venta
  itemName        String   // Nombre del producto al momento de la venta
  unitPrice       Float
  quantity        Int      @default(1)
  
  // Subtotal de esta lÃ­nea (unitPrice * quantity + modificadores)
  lineTotal       Float
  
  // Notas especiales (Ej: "Sin cebolla")
  notes           String?

  // Snapshot de costo (margen retroactivo)
  costPerUnit     Float?
  costTotal       Float?
  marginPerUnit   Float?
  marginPercent   Float?
  
  // Modificadores seleccionados
  modifiers       SalesOrderItemModifier[]
  
  @@index([orderId])
  @@index([menuItemId])
}

model SalesOrderItemModifier {
  id              String   @id @default(cuid())
  
  orderItemId     String
  orderItem       SalesOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  
  modifierId      String?
  modifier        MenuModifier? @relation(fields: [modifierId], references: [id])
  
  // Snapshot del nombre y ajuste de precio al momento de la venta
  name            String   // Nombre del modificador
  priceAdjustment Float    @default(0)
  
  @@index([orderItemId])
}

// ============================================================================
// INVENTARIO DIARIO
// ============================================================================

model DailyInventory {
  id          String   @id @default(cuid())
  date        DateTime // @db.Date no soportado en SQLite/algunas confs, usar DateTime normal y truncar
  areaId      String
  area        Area     @relation(fields: [areaId], references: [id])
  
  status      String   @default("DRAFT") // DRAFT, OPEN, CLOSED
  
  openedAt    DateTime?
  closedAt    DateTime?
  closedById  String?
  closedBy    User?    @relation(fields: [closedById], references: [id])
  
  totalVarianceValue Float?
  
  items       DailyInventoryItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?
  
  @@unique([date, areaId])
}

model DailyInventoryItem {
  id               String         @id @default(cuid())
  dailyInventoryId String
  dailyInventory   DailyInventory @relation(fields: [dailyInventoryId], references: [id], onDelete: Cascade)
  
  inventoryItemId  String
  inventoryItem    InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  
  initialCount     Float?   @default(0)
  finalCount       Float?   @default(0)
  
  // Movimientos calculados
  entries          Float    @default(0)
  sales            Float    @default(0)
  waste            Float    @default(0)
  
  theoreticalStock Float?
  variance         Float?
  
  unit             String
  costPerUnit      Float?
  
  notes            String?
  
  @@unique([dailyInventoryId, inventoryItemId])
}


// ============================================================================
// PRESTAMOS (LOANS)
// ============================================================================

model InventoryLoan {
  id              String   @id @default(cuid())
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  loaneeName      String   // Nombre del restaurante/persona
  quantity        Float
  unit            String
  
  type            String   // REPLACEMENT, PAYMENT
  status          String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  
  agreedPrice     Float?   // Precio unitario acordado (si es venta/pago)
  
  loanDate        DateTime @default(now())
  resolvedAt      DateTime?
  notes           String?
  
  createdById     String
  createdBy       User     @relation("LoanCreator", fields: [createdById], references: [id])

  // Movimientos asociados
  movements       InventoryMovement[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([status])
  @@index([loaneeName])
  @@index([createdById])
}

// ============================================================================
// AUDITORÍAS DE INVENTARIO
// ============================================================================

model InventoryAudit {
  id          String   @id @default(cuid())
  
  // Estado de la auditoría
  status      String   @default("DRAFT") // DRAFT, APPROVED, REJECTED
  
  // Metadatos
  name        String?  // Ej: "Inventario Mensual Enero"
  notes       String?
  areaId      String?
  area        Area?    @relation(fields: [areaId], references: [id])
  
  // Fecha efectiva: permite cargar auditorías retroactivas (ej: inventario del domingo cargado el lunes)
  effectiveDate DateTime? // Si no se especifica, se usa createdAt
  
  // Auditoría del registro
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("AuditCreator", fields: [createdById], references: [id])
  
  resolvedAt  DateTime?
  resolvedById String?
  resolvedBy   User?    @relation("AuditResolver", fields: [resolvedById], references: [id])
  
  // Relaciones
  items       InventoryAuditItem[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}

model InventoryAuditItem {
  id              String   @id @default(cuid())
  auditId         String
  audit           InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  // Valores
  systemStock     Float    // Stock que decía el sistema al momento de crear la auditoría
  countedStock    Float    // Stock real contado
  difference      Float    // Calculado: counted - system
  
  costSnapshot    Float?   // Costo unitario en ese momento
  
  notes           String?

  @@index([auditId])
  @@index([inventoryItemId])
}

// ============================================================================
// PROVEEDORES Y ÓRDENES DE COMPRA
// ============================================================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique // Código interno del proveedor
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Relaciones
  purchaseOrders PurchaseOrder[]
  // Productos que suministra este proveedor
  suppliedItems  SupplierItem[]
  // Procesamiento de Proteínas
  proteinProcessings ProteinProcessing[]
  // Módulo Financiero
  accountsPayable AccountPayable[]

  @@index([name])
}

// Relación entre Proveedor y los Items que puede suministrar
model SupplierItem {
  id              String        @id @default(cuid())
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  // Precio de referencia del proveedor
  unitPrice       Float?
  leadTimeDays    Int?          // Tiempo de entrega en días
  minimumOrder    Float?        // Cantidad mínima de pedido
  
  isPreferred     Boolean       @default(false) // Proveedor preferido para este item
  
  @@unique([supplierId, inventoryItemId])
  @@index([supplierId])
  @@index([inventoryItemId])
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // Ej: OC-2026-0001
  orderName       String?  // Nombre descriptivo: VEGETALES, COCHE, etc.
  
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  
  status          String   @default("DRAFT") // DRAFT, SENT, PARTIAL, RECEIVED, CANCELLED
  
  // Fechas
  orderDate       DateTime @default(now())
  expectedDate    DateTime? // Fecha esperada de recepción
  receivedDate    DateTime?
  
  // Totales
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  
  notes           String?
  internalNotes   String?  // Notas internas no visibles en la orden impresa
  
  // Auditoría
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  createdBy       User     @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  
  receivedById    String?
  receivedBy      User?    @relation("PurchaseOrderReceiver", fields: [receivedById], references: [id])

  // Items de la orden
  items           PurchaseOrderItem[]
  accountsPayable AccountPayable[]

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([status])
  @@index([orderDate])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  // Cantidades
  quantityOrdered Float         // Cantidad solicitada
  quantityReceived Float        @default(0) // Cantidad recibida
  unit            String
  
  // Precios
  unitPrice       Float         @default(0)
  totalPrice      Float         @default(0)
  
  // Información adicional
  notes           String?
  
  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

// ============================================================================
// AUDIT LOG - REGISTRO FORENSE DE OPERACIONES
// ============================================================================
// Esta tabla NUNCA se borra. Solo se puede archivar a cold storage.
// Toda server action que modifique datos debe crear un AuditLog.
// ============================================================================

model AuditLog {
  id            String   @id @default(cuid())

  // QUIÉN
  userId        String
  userName      String   // Snapshot para no depender de JOIN
  userRole      String   // Rol al momento de la acción

  // QUÉ
  action        String   // CREATE, UPDATE, DELETE, VOID, APPROVE, REJECT, LOGIN, LOGOUT
  entityType    String   // SalesOrder, InventoryMovement, Recipe, etc.
  entityId      String   // ID del registro afectado

  // DETALLE
  description   String?  // Descripción legible: "Creó orden REST-2026-03-15-001"
  changes       String?  // JSON: { field: { from: "X", to: "Y" } }
  metadata      String?  // JSON: datos contextuales adicionales

  // DESDE DÓNDE
  ipAddress     String?
  userAgent     String?
  deviceId      String?  // Identificador de terminal/caja

  // CUÁNDO
  createdAt     DateTime @default(now())

  // CONTEXTO OPERATIVO
  module        String?  // POS, INVENTORY, PRODUCTION, RECIPE, etc.

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([module])
}

// ============================================================================
// MÓDULO FINANCIERO - GASTOS, CAJA Y CUENTAS POR PAGAR
// ============================================================================

/// Categorías de gastos operativos (alquiler, servicios, nómina, etc.)
model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique  // ej: "Alquiler", "Servicios Públicos", "Nómina"
  description String?
  color       String?  // hex color para UI, ej: "#3B82F6"
  icon        String?  // emoji, ej: "🏠"
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses    Expense[]

  @@index([isActive])
}

/// Registro de gastos operativos (no de compras de inventario)
model Expense {
  id              String   @id @default(cuid())

  // Descripción
  description     String   // Ej: "Pago alquiler local enero 2026"
  notes           String?  // Notas adicionales o referencia

  // Clasificación
  categoryId      String
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])

  // Monto
  amountUsd       Float    // Monto en USD (moneda base del sistema)
  amountBs        Float?   // Monto en Bs (opcional, para referencia)
  exchangeRate    Float?   // Tasa usada para conversión

  // Pago
  paymentMethod   String   // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK, OTHER
  paymentRef      String?  // Referencia de pago (número de transacción, cheque, etc.)
  paidAt          DateTime // Fecha del pago/gasto

  // Estado
  status          String   @default("CONFIRMED") // CONFIRMED, VOID
  voidReason      String?
  voidedAt        DateTime?
  voidedById      String?

  // Comprobante
  receiptUrl      String?  // URL de imagen/PDF del comprobante (opcional)

  // Período al que pertenece
  periodMonth     Int      // 1-12
  periodYear      Int

  // Auditoría
  createdById     String
  createdBy       User     @relation("ExpenseCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
  @@index([paidAt])
  @@index([periodYear, periodMonth])
  @@index([status])
  @@index([createdById])
}

/// Apertura y cierre de caja (para cuadre de efectivo al inicio/fin del turno)
model CashRegister {
  id              String   @id @default(cuid())

  // Identificador de caja/terminal
  registerName    String   // ej: "Caja Restaurante", "Caja Delivery"
  shiftDate       DateTime // Fecha del turno (solo fecha, sin hora)
  shiftType       String   @default("DAY") // DAY, NIGHT, MORNING

  // Estado
  status          String   @default("OPEN") // OPEN, CLOSED

  // Apertura
  openingCashUsd  Float    @default(0)  // Fondo inicial en USD
  openingCashBs   Float    @default(0)  // Fondo inicial en Bs
  openedAt        DateTime @default(now())
  openedById      String
  openedBy        User     @relation("CashRegisterOpener", fields: [openedById], references: [id])

  // Cierre
  closingCashUsd  Float?   // Efectivo contado al cierre en USD
  closingCashBs   Float?   // Efectivo contado al cierre en Bs
  closedAt        DateTime?
  closedById      String?
  closedBy        User?    @relation("CashRegisterCloser", fields: [closedById], references: [id])

  // Resumen calculado al cierre
  totalSalesUsd   Float?   // Total ventas del turno
  totalExpenses   Float?   // Total gastos del turno
  expectedCash    Float?   // Efectivo esperado (apertura + ventas efectivo - gastos)
  difference      Float?   // Diferencia (cierre contado - esperado)

  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shiftDate])
  @@index([status])
  @@index([openedById])
}

/// Cuentas por pagar — facturas/deudas pendientes con proveedores u otros acreedores
model AccountPayable {
  id              String   @id @default(cuid())

  // Descripción
  description     String   // Ej: "Factura vegetales 15/03/2026"
  invoiceNumber   String?  // Número de factura del proveedor
  invoiceUrl      String?  // URL del comprobante

  // Acreedor
  supplierId      String?  // Si es un proveedor del sistema
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  creditorName    String?  // Si no está en el sistema de proveedores

  // Montos
  totalAmountUsd  Float    // Monto total de la deuda en USD
  paidAmountUsd   Float    @default(0) // Monto pagado acumulado
  remainingUsd    Float    // Monto pendiente (calculado: total - paid)

  // Fechas
  invoiceDate     DateTime // Fecha de la factura
  dueDate         DateTime? // Fecha de vencimiento (opcional)
  fullyPaidAt     DateTime? // Fecha en que quedó saldada

  // Estado
  status          String   @default("PENDING") // PENDING, PARTIAL, PAID, OVERDUE, DISPUTED, VOID

  // Relación con PurchaseOrder (si aplica)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Auditoría
  createdById     String
  createdBy       User     @relation("AccountPayableCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        AccountPayment[]

  @@index([status])
  @@index([dueDate])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([createdById])
}

/// Pagos individuales aplicados a una cuenta por pagar
model AccountPayment {
  id               String         @id @default(cuid())
  accountPayableId String
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)

  amountUsd        Float
  amountBs         Float?
  exchangeRate     Float?
  paymentMethod    String   // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK
  paymentRef       String?  // Referencia de transferencia, cheque, etc.
  paidAt           DateTime

  notes            String?

  createdById      String
  createdBy        User     @relation("AccountPaymentCreator", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())

  @@index([accountPayableId])
  @@index([paidAt])
}

// ============================================================================
// MODELO OPERATIVO RESTAURANTE
// ============================================================================

model Branch {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  legalName     String?
  timezone      String   @default("America/Caracas")
  currencyCode  String   @default("USD")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Soft Delete
  deletedAt     DateTime?
  deletedById   String?

  areas           Area[]
  serviceZones    ServiceZone[]
  tableOrStations TableOrStation[]
  openTabs        OpenTab[]
  salesOrders     SalesOrder[]
  gameStations    GameStation[]
  waiters         Waiter[]
}

model Waiter {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, isActive])
}

model ServiceZone {
  id            String   @id @default(cuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code          String?
  name          String
  zoneType      String   @default("DINING") // DINING, BAR, TERRACE, VIP
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tablesOrStations TableOrStation[]
  openTabs      OpenTab[]
  salesOrders   SalesOrder[]

  @@unique([branchId, name])
  @@index([branchId, zoneType])
}

model TableOrStation {
  id            String   @id @default(cuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId String
  serviceZone   ServiceZone @relation(fields: [serviceZoneId], references: [id], onDelete: Cascade)
  code          String
  name          String
  stationType   String   @default("TABLE") // TABLE, BAR_SEAT, VIP_ROOM
  capacity      Int      @default(1)
  currentStatus String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, OUT_OF_SERVICE
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  openTabs      OpenTab[]
  salesOrders   SalesOrder[]

  @@unique([branchId, code])
  @@index([serviceZoneId, stationType])
  @@index([currentStatus])
}

model OpenTab {
  id              String   @id @default(cuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId   String?
  serviceZone     ServiceZone? @relation(fields: [serviceZoneId], references: [id])
  tableOrStationId String?
  tableOrStation  TableOrStation? @relation(fields: [tableOrStationId], references: [id])
  tabCode         String   @unique
  customerLabel   String?
  customerPhone   String?
  guestCount      Int      @default(1)
  status          String   @default("OPEN") // OPEN, PARTIALLY_PAID, CLOSED, CANCELLED
  serviceType     String   @default("TABLE_SERVICE") // TABLE_SERVICE, BAR_TAB, EVENT
  runningSubtotal      Float @default(0)
  runningDiscount      Float @default(0)
  runningTax           Float @default(0)
  runningTotal         Float @default(0)
  balanceDue           Float @default(0)
  totalServiceCharge   Float @default(0)  // Service charge acumulado de la mesa
  totalTip             Float @default(0)  // Propina voluntaria acumulada
  version         Int      @default(0)
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  updatedAt       DateTime @updatedAt
  notes           String?
  waiterLabel     String?
  openedById      String
  openedBy        User     @relation("OpenTabOpener", fields: [openedById], references: [id])
  assignedWaiterId String?
  assignedWaiter  User?    @relation("OpenTabAssignee", fields: [assignedWaiterId], references: [id])
  closedById      String?
  closedBy        User?    @relation("OpenTabCloser", fields: [closedById], references: [id])

  orders          SalesOrder[]
  orderLinks      OpenTabOrder[]
  paymentSplits   PaymentSplit[]

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([branchId, status])
  @@index([tableOrStationId])
}

model OpenTabOrder {
  id            String   @id @default(cuid())
  openTabId     String
  openTab       OpenTab  @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId  String
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  addedAt       DateTime @default(now())

  @@unique([openTabId, salesOrderId])
  @@index([salesOrderId])
}

model PaymentSplit {
  id            String   @id @default(cuid())
  openTabId      String
  openTab        OpenTab   @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId   String?
  salesOrder     SalesOrder? @relation(fields: [salesOrderId], references: [id])
  splitLabel     String
  splitType      String   @default("EQUAL") // EQUAL, ITEM_BASED, CUSTOM
  paymentMethod  String?
  status         String   @default("PENDING") // PENDING, PAID, VOID
  subtotal             Float @default(0)
  discount             Float @default(0)
  tax                  Float @default(0)
  serviceChargeAmount  Float @default(0) // Cargo de servicio prorrateado en este split
  tipAmount            Float @default(0) // Propina prorrateada en este split
  total                Float @default(0)
  paidAmount           Float @default(0)
  createdAt      DateTime @default(now())
  paidAt         DateTime?
  notes          String?

  @@index([openTabId, status])
  @@index([salesOrderId])
}

// ============================================================================
// TASA DE CAMBIO USD / BOLÍVARES (BCV)
// ============================================================================

// ============================================================================
// CONFIGURACIÓN DEL SISTEMA (clave-valor persistente)
// ============================================================================
// Usada para guardar config de instalación sin depender de variables de entorno.
// Clave: 'enabled_modules' → valor: JSON array de ids de módulos activos.

model SystemConfig {
  key       String   @id          // 'enabled_modules', 'business_name', etc.
  value     String               // JSON string o texto plano
  updatedAt DateTime @updatedAt
  updatedBy String?              // userId quien lo cambió
}

model ExchangeRate {
  id            String   @id @default(cuid())
  rate          Float    // Bs por 1 USD
  effectiveDate DateTime
  source        String   @default("BCV")
  createdAt     DateTime @default(now())

  salesOrders   SalesOrder[]

  @@index([effectiveDate])
}

// ============================================================================
// MÓDULO ENTRETENIMIENTO / JUEGOS (Table-Pong)
// ============================================================================

model GameType {
  id          String   @id @default(cuid())
  code        String   @unique  // BILLAR, PLAYSTATION, PING_PONG, ARCADE, etc.
  name        String
  description String?
  icon        String?
  color       String?  // Hex color para UI
  defaultSessionMinutes Int @default(60)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stations    GameStation[]
  sessions    GameSession[]

  @@index([code])
}

model GameStation {
  id            String   @id @default(cuid())
  code          String   @unique  // BILLAR-01, PS5-01, etc.
  name          String
  gameTypeId    String
  gameType      GameType @relation(fields: [gameTypeId], references: [id])
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  currentStatus String   @default("AVAILABLE") // AVAILABLE, IN_USE, RESERVED, MAINTENANCE
  hourlyRate    Float?   // Precio por hora (null = pulsera / flat fee)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      GameSession[]
  reservations  Reservation[]
  queueTickets  QueueTicket[]

  @@index([gameTypeId])
  @@index([currentStatus])
  @@index([branchId])
}

model WristbandPlan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String   // Ej: "Pulsera Básica 2h", "Pulsera Premium Full Day"
  description   String?
  durationMinutes Int    // Duración total en minutos
  price         Float
  color         String?  // Color físico de la pulsera
  maxSessions   Int?     // Nº máximo de estaciones simultáneas (null = ilimitado)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservations  Reservation[]

  @@index([isActive])
}

model Reservation {
  id              String   @id @default(cuid())
  code            String   @unique  // RES-2026-0001
  stationId       String
  station         GameStation @relation(fields: [stationId], references: [id])
  wristbandPlanId String?
  wristbandPlan   WristbandPlan? @relation(fields: [wristbandPlanId], references: [id])
  customerName    String
  customerPhone   String?
  guestCount      Int      @default(1)
  scheduledStart  DateTime
  scheduledEnd    DateTime
  status          String   @default("PENDING") // PENDING, CONFIRMED, CHECKED_IN, NO_SHOW, CANCELLED
  notes           String?
  depositAmount   Float    @default(0)
  depositPaid     Boolean  @default(false)
  createdById     String
  createdBy       User     @relation("ReservationCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session         GameSession?

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  @@index([stationId, scheduledStart])
  @@index([status])
  @@index([customerPhone])
}

model GameSession {
  id              String   @id @default(cuid())
  code            String   @unique  // GSN-2026-0001
  stationId       String
  station         GameStation @relation(fields: [stationId], references: [id])
  gameTypeId      String
  gameType        GameType @relation(fields: [gameTypeId], references: [id])
  reservationId   String?  @unique
  reservation     Reservation? @relation(fields: [reservationId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder? @relation("GameSessions", fields: [salesOrderId], references: [id])
  wristbandCode   String?  // Código físico de la pulsera escaneada
  customerName    String?
  guestCount      Int      @default(1)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  scheduledEndAt  DateTime?
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, ENDED, OVERTIME
  billingType     String   @default("HOURLY") // HOURLY, WRISTBAND, FLAT
  minutesBilled   Int      @default(0)
  amountBilled    Float    @default(0)
  notes           String?
  startedById     String
  startedBy       User     @relation("GameSessionStarter", fields: [startedById], references: [id])
  endedById       String?
  endedBy         User?    @relation("GameSessionEnder", fields: [endedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([stationId, status])
  @@index([startedAt])
  @@index([salesOrderId])
}

model QueueTicket {
  id          String   @id @default(cuid())
  ticketNumber Int     // Correlativo del turno (reset por día)
  stationId   String?
  station     GameStation? @relation(fields: [stationId], references: [id])
  gameTypeId  String?  // Si solo pide tipo de juego (cualquier estación)
  customerName String
  customerPhone String?
  guestCount  Int      @default(1)
  status      String   @default("WAITING") // WAITING, CALLED, SEATED, EXPIRED, CANCELLED
  calledAt    DateTime?
  seatedAt    DateTime?
  estimatedWaitMinutes Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([stationId])
}

// ============================================================================
// MÓDULO INTERCOMPANY (Multi-Negocio)
// ============================================================================

model IntercompanySettlement {
  id              String   @id @default(cuid())
  code            String   @unique  // IC-2026-0001
  fromBranchId    String   // Negocio que provee
  toBranchId      String   // Negocio que recibe
  periodStart     DateTime
  periodEnd       DateTime
  status          String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, PAID, DISPUTED
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  notes           String?
  approvedById    String?
  approvedAt      DateTime?
  paidAt          DateTime?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft Delete
  deletedAt       DateTime?
  deletedById     String?

  lines           IntercompanySettlementLine[]

  @@index([fromBranchId, toBranchId])
  @@index([status])
  @@index([periodStart])
}

model IntercompanySettlementLine {
  id               String   @id @default(cuid())
  settlementId     String
  settlement       IntercompanySettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  menuItemId       String?
  inventoryItemId  String?
  description      String
  quantity         Float
  unit             String
  unitPrice        Float
  totalPrice       Float
  notes            String?
  sortOrder        Int      @default(0)

  @@index([settlementId])
}

model IntercompanyItemMapping {
  id               String   @id @default(cuid())
  // El MenuItem en el negocio receptor
  menuItemId       String
  menuItem         MenuItem @relation("IntercompanyMenuItem", fields: [menuItemId], references: [id], onDelete: Cascade)
  // El InventoryItem en el negocio proveedor que se debe descontar
  sourceInventoryItemId String
  fromBranchId     String
  toBranchId       String
  transferPrice    Float?   // Precio de transferencia intercompany
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@unique([menuItemId, fromBranchId])
  @@index([fromBranchId, toBranchId])
}

// ============================================================================
// MÓDULOS DE ADMINISTRACIÓN AVANZADA
// ============================================================================

// Familia de productos (SKU Studio)
model ProductFamily {
  id          String   @id @default(cuid())
  code        String   @unique  // Ej: SHAWARMA, BEBIDA, POSTRE
  name        String
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       InventoryItem[]
  templates   SkuCreationTemplate[]

  @@index([code])
}

// Plantilla para crear SKUs rápidamente desde el SKU Studio
model SkuCreationTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  productFamilyId String?
  productFamily   ProductFamily? @relation(fields: [productFamilyId], references: [id])
  // JSON con los campos pre-rellenados para crear InventoryItem + MenuItem
  defaultFields   String   // JSON
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productFamilyId])
}

// Mensajes broadcast (anuncios internos)
model BroadcastMessage {
  id          String   @id @default(cuid())
  title       String
  body        String
  type        String   @default("INFO") // INFO, WARNING, ALERT, SUCCESS
  targetRoles String?  // JSON array de roles que lo ven (null = todos)
  isActive    Boolean  @default(true)
  startsAt    DateTime @default(now())
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime @default(now())

  @@index([isActive, startsAt])
  @@index([type])
}

// Ciclo de Conteo Físico (Inventario Semanal/Mensual)
model InventoryCycle {
  id          String   @id @default(cuid())
  code        String   @unique  // CYCLE-2026-W12
  name        String   // Ej: "Conteo Semana 12 - 2026"
  cycleType   String   @default("WEEKLY") // WEEKLY, MONTHLY, SPOT_CHECK
  areaIds     String   // JSON array de IDs de área incluidos
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, CLOSED, CANCELLED
  startedAt   DateTime @default(now())
  closedAt    DateTime?
  closedById  String?
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  snapshots   InventoryCycleSnapshot[]

  @@index([status])
  @@index([cycleType])
  @@index([startedAt])
}

model InventoryCycleSnapshot {
  id              String   @id @default(cuid())
  cycleId         String
  cycle           InventoryCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  areaId          String
  countedStock    Float    // Conteo físico real
  systemStock     Float    // Stock del sistema al momento del conteo
  difference      Float    // counted - system
  unit            String
  costSnapshot    Float?
  countedById     String
  countedAt       DateTime @default(now())
  notes           String?

  @@unique([cycleId, inventoryItemId, areaId])
  @@index([cycleId])
  @@index([inventoryItemId])
}
